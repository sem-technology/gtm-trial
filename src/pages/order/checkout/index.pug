extends ../../../layout/_baseof

block load_scripts
  script(src="/main.ts" type="module")

block content
  // ##### Breadcumb Area Start #####
  div(class="breadcumb_area bg-img", style="background-image: url(/img/bg-img/breadcumb.png);")
    .container.h-100
      .row.h-100.align-items-center
        .col-12
          .page-title.text-center
            h2 お支払い・お届け先
  // ##### Breadcumb Area End #####
  // ##### Checkout Area Start #####
  div(class="checkout_area section-padding-80")
    .container
      .row
        .col-12.col-md-6
          div(class="checkout_details_area mt-50 clearfix")
            .cart-page-heading.mb-30
              h5 お届け先情報
            form(action="#", method="post")
              .row
                .col-md-6.mb-3
                  label(for="last_name") 姓 
                    span *
                  input.form-control(type="text", id="last_name", name="last_name", value="", required)
                .col-md-6.mb-3
                  label(for="first_name") 名 
                    span *
                  input.form-control(type="text", id="first_name", name="first_name", value="", required)
                .col-12.mb-3
                  label(for="company") 会社名
                  input#company.form-control(type="text", name="company", value="")
                .col-12.mb-3
                  label(for="country") 国 
                    span *
                  select#country.w-100(name="country")
                    option(value="usa") United States
                    option(value="uk") United Kingdom
                    option(value="ger") Germany
                    option(value="fra") France
                    option(value="ind") India
                    option(value="aus") Australia
                    option(value="bra") Brazil
                    option(value="cana") Canada
                    option(value="jpn" selected) 日本
                .col-12.mb-3
                  label(for="postcode") 郵便番号 
                    span *
                  input#postcode.form-control(type="text", name="postcode", value="")
                .col-12.mb-3
                  label(for="state") 都道府県 
                    span *
                  input#state.form-control(type="text", name="state", value="")
                .col-12.mb-3
                  label(for="city") 市区町村 
                    span *
                  input#city.form-control(type="text", name="city", value="")
                .col-12.mb-3
                  label(for="street_address") 住所（番地・建物名） 
                    span *
                  input.form-control.mb-3(type="text", id="street_address", name="street_address", value="")
                  input.form-control(type="text", id="street_address2", name="street_address2", value="")
                .col-12.mb-3
                  label(for="phone_number") 電話番号 
                    span *
                  input.form-control(type="number", id="phone_number", name="phone_number", min="0", value="")
                .col-12.mb-4
                  label(for="email_address") メールアドレス 
                    span *
                  input.form-control(type="email", id="email_address", name="email_address", value="")
                .col-12
                  .custom-control.custom-checkbox.d-block.mb-2
                    input#customCheck1.custom-control-input(type="checkbox", name="terms")
                    label.custom-control-label(for="customCheck1") 利用規約に同意する
                  .custom-control.custom-checkbox.d-block.mb-2
                    input#customCheck2.custom-control-input(type="checkbox", name="create_account")
                    label.custom-control-label(for="customCheck2") アカウントを作成する
                  .custom-control.custom-checkbox.d-block
                    input#customCheck3.custom-control-input(type="checkbox", name="subscribe")
                    label.custom-control-label(for="customCheck3") ニュースレターを購読する
        .col-12.col-md-6.col-lg-5.ml-lg-auto
          .order-details-confirmation
            .cart-page-heading
              h5 ご注文内容
              p 詳細
            ul.order-details-form.mb-4
              li
                span 商品名
                span 合計
              li
                span 高級万年筆
                span ¥24,000
              li
                span 栃木レザー製ペンケース
                span ¥19,200
              li
                span 小計
                span ¥43,200
              li
                span 送料
                span 無料
              li
                span 合計
                span ¥43,200
            #accordion.mb-4(role="tablist")
              .card
                #headingOne.card-header(role="tab")
                  h6.mb-0
                    a(data-toggle="collapse", href="#collapseOne", aria-expanded="false", aria-controls="collapseOne")
                      i.fa.fa-circle-o.mr-3
                      | Paypal
                #collapseOne.collapse(role="tabpanel", aria-labelledby="headingOne", data-parent="#accordion")
                  .card-body
                    p PayPalでのお支払いが可能です。
              .card
                #headingTwo.card-header(role="tab")
                  h6.mb-0
                    a.collapsed(data-toggle="collapse", href="#collapseTwo", aria-expanded="false", aria-controls="collapseTwo")
                      i.fa.fa-circle-o.mr-3
                      | 代金引換
                #collapseTwo.collapse(role="tabpanel", aria-labelledby="headingTwo", data-parent="#accordion")
                  .card-body
                    p 商品お届け時に、配達員に代金をお支払いください。
              .card
                #headingThree.card-header(role="tab")
                  h6.mb-0
                    a.collapsed(data-toggle="collapse", href="#collapseThree", aria-expanded="false", aria-controls="collapseThree")
                      i.fa.fa-circle-o.mr-3
                      | クレジットカード
                #collapseThree.collapse(role="tabpanel", aria-labelledby="headingThree", data-parent="#accordion")
                  .card-body
                    p 各種クレジットカードをご利用いただけます。
              .card
                #headingFour.card-header(role="tab")
                  h6.mb-0
                    a.collapsed(data-toggle="collapse", href="#collapseFour", aria-expanded="true", aria-controls="collapseFour")
                      i.fa.fa-circle-o.mr-3
                      | 銀行振込
                #collapseFour.collapse.show(role="tabpanel", aria-labelledby="headingThree", data-parent="#accordion")
                  .card-body
                    p 指定の銀行口座へお振込みをお願いいたします。振込手数料はお客様のご負担となります。
            a.btn.essence-btn(href="/order/complete/index.html") 注文を確定する
  // ##### Checkout Area End #####
